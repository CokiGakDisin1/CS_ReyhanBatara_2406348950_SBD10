{
  "version": 2,
  "builds": [
    {
      "src": "Resources/Resources/backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "tp-modul-10/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "Resources/Resources/backend/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "tp-modul-10/$1" }
  ]
}
